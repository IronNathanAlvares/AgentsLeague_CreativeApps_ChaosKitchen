# Copy this file to .env and fill values
# The server reads these values (not the browser).

# Your OpenAI-compatible chat completions base URL (without trailing slash)
# Example OpenAI: https://api.openai.com/v1
# Example GitHub Models: https://models.inference.ai.azure.com
MODEL_API_BASE_URL=https://api.openai.com/v1

# Your API key/token (never commit real values)
MODEL_API_KEY=

# Model name exposed by your provider
MODEL_NAME=gpt-4.1-mini

# Optional auth configuration
MODEL_AUTH_HEADER=Authorization
MODEL_AUTH_SCHEME=Bearer

# Optional server port (default 8787)
SERVER_PORT=8787
